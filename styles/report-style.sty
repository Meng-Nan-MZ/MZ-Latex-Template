\renewcommand{\cftaftertoctitle}{}
\setlength{\cftbeforetoctitleskip}{0pt}
\setlength{\cftaftertoctitleskip}{1.2em}

\renewcommand{\cftchapfont}{\bfseries\zihao{-4}}
\renewcommand{\cftchappagefont}{\zihao{-4}}
\renewcommand{\cftsecfont}{\zihao{-4}}
\renewcommand{\cftsecpagefont}{\zihao{-4}}
\renewcommand{\cftsubsecfont}{\zihao{-4}}
\renewcommand{\cftsubsecpagefont}{\zihao{-4}}

\cftsetindents{chapter}{0em}{2.2em}
\cftsetindents{section}{2.2em}{2.8em}
\cftsetindents{subsection}{5.0em}{3.4em}

\renewcommand{\cftdotsep}{1.8}
\setlength{\cftbeforechapskip}{0.35em}
\setlength{\cftbeforesecskip}{0.2em}
\setlength{\cftbeforesubsecskip}{0.1em}

\makeatletter
\renewcommand{\thesubsubsection}{\thesubsection.\arabic{subsubsection}}
\renewcommand{\theparagraph}{\thesubsubsection.\arabic{paragraph}}
\renewcommand{\thesubparagraph}{\theparagraph.\arabic{subparagraph}}

\renewcommand\subsubsection{%
  \@startsection{subsubsection}{3}{0pt}%
  {1.0ex \@plus .2ex \@minus .2ex}%
  {1.0ex}%
  {\normalfont\normalsize\bfseries}%
}

\renewcommand\paragraph[1]{%
  \par\vspace{1.0ex \@plus .2ex \@minus .2ex}%
  \refstepcounter{paragraph}%
  \noindent{\normalfont\normalsize\bfseries\theparagraph\quad #1}\par\nobreak
  \vspace{1.0ex}%
}

\renewcommand\subparagraph[1]{%
  \par\vspace{1.0ex \@plus .2ex \@minus .2ex}%
  \refstepcounter{subparagraph}%
  \noindent{\normalfont\normalsize\bfseries\thesubparagraph\quad #1}\par\nobreak
  \vspace{1.0ex}%
}
\makeatother

\setlength{\parindent}{2em}
\setlength{\parskip}{0.3em}
\setlist[itemize]{itemsep=0.3em, topsep=0.3em}
\setlist[enumerate]{itemsep=0.3em, topsep=0.3em}

% 报告表格统一样式。
% 用途：替代 Word 导入后常见的全边框表格，使用 booktabs 三线表、
% 较紧凑的字号和行距，并为长表保留稳定的跨页排版。
\definecolor{mzTableStripe}{HTML}{F7F9FB}
\definecolor{mzTableRule}{HTML}{8A97A6}
\newenvironment{mzTable}{%
  \par\addvspace{0.9\baselineskip}%
  \begingroup
  \scriptsize
  \setlength{\tabcolsep}{3pt}%
  \renewcommand{\arraystretch}{1.22}%
  \setlength{\LTpre}{0pt}%
  \setlength{\LTpost}{0.65em}%
  \arrayrulecolor{mzTableRule}%
  \rowcolors{2}{mzTableStripe}{white}%
}{%
  \rowcolors{2}{}{}%
  \arrayrulecolor{black}%
  \endgroup
  \par\addvspace{0.25\baselineskip}%
}

% 测试用例块排版工具。
% 用途：把从 Word 导入的“测试步骤 / 预期结果 / 实际运行结果 / 测试结论”
% 统一排成紧凑的测试用例格式，并模拟 Word 中整体按一次 Tab 后的左缩进。
% 用法：
%   \begin{mzTestCaseBlock}
%   \mzTestBlockTitle{测试步骤}
%   \begin{enumerate}
%     \item ...
%   \end{enumerate}
%   \mzTestBlockTitle{测试结论}
%   测试通过。
%   \end{mzTestCaseBlock}
%
% 小标题格式：显示为“黑色方块 + 箭头 + 加粗标题”。
\newcommand{\mzTestBlockTitle}[1]{%
  \par\addvspace{0.45\baselineskip}%
  \noindent\makebox[2.0em][l]{\raisebox{0.12ex}{\rule{0.72em}{0.72em}}\,\(\to\)}%
  {\bfseries #1}\par\nobreak\vspace{0.12\baselineskip}%
}

% 半角直双引号：避免正文中的普通 " 被字体排成中文/弯引号。
\newcommand{\mzDq}{\texttt{\symbol{34}}}

% 直引号代码片段：用于路径、挂载点等需要显示 ASCII 双引号的内容。
\newcommand{\mzQuotedCode}[1]{\texttt{\symbol{34}#1\symbol{34}}}

% 测试用例正文环境：整体左缩进 2em，并压缩 enumerate 的上下间距。
\newenvironment{mzTestCaseBlock}{%
  \begingroup
  \setlength{\parskip}{0pt}%
  \begin{list}{}{%
    \setlength{\leftmargin}{2em}%
    \setlength{\rightmargin}{0pt}%
    \setlength{\listparindent}{0pt}%
    \setlength{\itemindent}{0pt}%
    \setlength{\parsep}{0pt}%
    \setlength{\topsep}{0pt}%
    \setlength{\partopsep}{0pt}%
  }%
  \item\relax
  \setlist[enumerate]{%
    label=\arabic*.,
    labelindent=0pt,
    labelwidth=1.55em,
    labelsep=0.25em,
    leftmargin=!,
    align=left,
    itemsep=0.12\baselineskip,
    topsep=0.12\baselineskip,
    parsep=0pt,
    partopsep=0pt
  }%
}{%
  \par\end{list}\endgroup
}

