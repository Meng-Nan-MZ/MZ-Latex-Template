\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{styles/report-style}[2026/06/17 Chinese report style]

\RequirePackage[
  a4paper,
  left=3.18cm,
  right=3.18cm,
  top=2.54cm,
  bottom=2.54cm,
  bindingoffset=0cm
]{geometry}
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{booktabs}
\RequirePackage{longtable}
\RequirePackage{array}
\RequirePackage{multirow}
\RequirePackage{subcaption}
\RequirePackage{float}
\RequirePackage{enumitem}
\RequirePackage{etoolbox}
\RequirePackage{hyperref}
\RequirePackage{xcolor}
\RequirePackage{listings}
\RequirePackage[most]{tcolorbox}
\RequirePackage{fancyhdr}
\RequirePackage{tocloft}
\RequirePackage{placeins}
\RequirePackage{tikz}
\RequirePackage{adjustbox}

% Global document structure and numbering depth.
\setcounter{tocdepth}{3}
\setcounter{secnumdepth}{5}

\usetikzlibrary{arrows.meta, shapes.geometric, positioning, fit, backgrounds}
\graphicspath{{figures/}}
\captionsetup{labelsep=space}

\hypersetup{hidelinks}

% Code blocks for C examples in technical reports.
% The color palette follows the Visual Studio Classic light theme.
\definecolor{mzCodeBg}{HTML}{FFFFFF}
\definecolor{mzCodeFrame}{HTML}{D0D7DE}
\definecolor{mzCodeTitle}{HTML}{EEF2F6}
\definecolor{mzCodeKeyword}{HTML}{0000FF}
\definecolor{mzCodeComment}{HTML}{008000}
\definecolor{mzCodeString}{HTML}{A31515}
\definecolor{mzCodeNumber}{HTML}{6A737D}
\IfFontExistsTF{Consolas}
  {\newfontfamily\mzCodeFont{Consolas}[Scale=MatchLowercase]}
  {\newcommand{\mzCodeFont}{\ttfamily}}

\lstdefinestyle{mz-c}{
  language=C,
  basicstyle=\mzCodeFont\small,
  keywordstyle=\color{mzCodeKeyword},
  directivestyle=\color{mzCodeKeyword},
  commentstyle=\color{mzCodeComment},
  stringstyle=\color{mzCodeString},
  morekeywords={bool,true,false,uint8_t,uint16_t,uint32_t,int8_t,int16_t,int32_t,size_t},
  numbers=left,
  numberstyle=\scriptsize\color{mzCodeNumber},
  stepnumber=1,
  numbersep=10pt,
  showstringspaces=false,
  breaklines=true,
  breakatwhitespace=false,
  tabsize=2,
  columns=fullflexible,
  keepspaces=true,
  upquote=true
}

\newtcblisting{cbox}[2][]{
  enhanced,
  breakable,
  colback=mzCodeBg,
  colframe=mzCodeFrame,
  coltitle=black,
  colbacktitle=mzCodeTitle,
  fonttitle=\bfseries,
  title={#2},
  arc=2pt,
  boxrule=0.5pt,
  left=7mm,
  right=1mm,
  top=1mm,
  bottom=1mm,
  listing only,
  listing options={style=mz-c},
  #1
}

\ctexset{
  contentsname = {\hfill 目\quad 录\hfill\null},
  chapter = {
    format = {\bfseries\zihao{3}\raggedright},
    name = {},
    number = {\chinese{chapter}},
    aftername = {、},
    beforeskip = 0pt,
    afterskip = 1.2ex,
  },
  section = {
    format = {\bfseries\zihao{4}\raggedright},
  },
  subsection = {
    format = {\bfseries\normalsize\raggedright},
    indent = 0pt,
  }
}

% 目录样式微调：标题、缩进、点线和间距
\renewcommand{\cfttoctitlefont}{\bfseries\zihao{3}}
\renewcommand{\cftaftertoctitle}{}
\setlength{\cftbeforetoctitleskip}{0pt}
\setlength{\cftaftertoctitleskip}{1.2em}

\renewcommand{\cftchapfont}{\bfseries\zihao{-4}}
\renewcommand{\cftchappagefont}{\zihao{-4}}
\renewcommand{\cftsecfont}{\zihao{-4}}
\renewcommand{\cftsecpagefont}{\zihao{-4}}
\renewcommand{\cftsubsecfont}{\zihao{-4}}
\renewcommand{\cftsubsecpagefont}{\zihao{-4}}

\cftsetindents{chapter}{0em}{2.2em}
\cftsetindents{section}{2.2em}{2.8em}
\cftsetindents{subsection}{5.0em}{3.4em}

\renewcommand{\cftdotsep}{1.8}
\setlength{\cftbeforechapskip}{0.35em}
\setlength{\cftbeforesecskip}{0.2em}
\setlength{\cftbeforesubsecskip}{0.1em}

\makeatletter
\renewcommand{\thesubsubsection}{\thesubsection.\arabic{subsubsection}}
\renewcommand{\theparagraph}{\thesubsubsection.\arabic{paragraph}}
\renewcommand{\thesubparagraph}{\theparagraph.\arabic{subparagraph}}

\renewcommand\subsubsection{%
  \@startsection{subsubsection}{3}{0pt}%
  {1.0ex \@plus .2ex \@minus .2ex}%
  {1.0ex}%
  {\normalfont\normalsize\bfseries}%
}

\renewcommand\paragraph[1]{%
  \par\vspace{1.0ex \@plus .2ex \@minus .2ex}%
  \refstepcounter{paragraph}%
  \noindent{\normalfont\normalsize\bfseries\theparagraph\quad #1}\par\nobreak
  \vspace{1.0ex}%
}

\renewcommand\subparagraph[1]{%
  \par\vspace{1.0ex \@plus .2ex \@minus .2ex}%
  \refstepcounter{subparagraph}%
  \noindent{\normalfont\normalsize\bfseries\thesubparagraph\quad #1}\par\nobreak
  \vspace{1.0ex}%
}
\makeatother

\setlength{\parindent}{2em}
\setlength{\parskip}{0.3em}
\setlist[itemize]{itemsep=0.3em, topsep=0.3em}
\setlist[enumerate]{itemsep=0.3em, topsep=0.3em}

\fancyhf{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
